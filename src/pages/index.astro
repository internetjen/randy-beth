---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import heroBg from '../assets/images/Randy_Beth_Classy_4.jpeg';
---

<BaseLayout title="Randy Beth">
  <section class="hero-wrapper">
    <div class="hero">
      <Image src={heroBg} alt="Randy Beth" class="hero-img" />
      <div class="hero-overlay"></div>
      <div class="hero-content">
        <p class="hero-eyebrow">New Single</p>
        <h1 class="hero-title">Randy Beth</h1>
        <p class="hero-single">"Classy" — Out Now</p>
        <a href="/listen" class="hero-btn">Listen Now</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 100px 80px 80px;
    min-height: 100vh;
  }

  .hero {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .hero-overlay {
  position: absolute;
  inset: 0;
  background: radial-gradient(
    ellipse at center,
    rgba(13, 26, 16, 0.45) 0%,
    rgba(13, 26, 16, 0.65) 100%
  );
}

  .hero-content {
    position: relative;
    z-index: 10;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    animation: fadeUp 1.4s ease forwards;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .hero-eyebrow {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(40px, 7vw, 90px);
    font-weight: 500;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.5);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--cream);
    line-height: 1;
  }

  .hero-single {
    font-family: var(--font-display);
    font-size: clamp(14px, 1.8vw, 20px);
    font-weight: 700;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.5);
    font-style: italic;
    color: var(--cream);
    letter-spacing: 0.1em;
  }

  .hero-btn {
    margin-top: 8px;
    padding: 12px 36px;
    background: var(--gold);
    border: 1px solid var(--gold);
    color: var(--green-deep);
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    transition: background 0.3s, color 0.3s;
  }

  .hero-btn:hover {
    background: var(--gold-light);
  }

  @media (max-width: 768px) {
  .hero-wrapper {
    padding: 80px 24px 40px;
  }

  .hero {
    aspect-ratio: 4 / 5;
  }
}
</style>